    <h1 class="title">The Sports Business as a Labor Market Laboratory</h1>
    <ul class="attribution">
            <li class='author' style='margin-bottom:0.5em; '>
         Lawrence M. Kahn    </li>

    </ul>

		<div style='margin-top:25px;'>

			<div class='journal'>Journal of Economic Perspectives </div>

			                <div class="journal">
                    <a href="/issues/130" style="color:inherit !important;">
					vol. 14,
					no. 3, 					Summer 2000					</a>
				</div>

		</div>
                <div class="pages">(pp. 75&ndash;94)</div>
		
    
	
    <section class='download'>
        <a class="button" href="/articles/pdf/doi/10.1257/jep.14.3.75">
            Download Full Text PDF <br/>
            (Complimentary)        </a>
